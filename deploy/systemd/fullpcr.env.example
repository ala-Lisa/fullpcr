# fullpcr environment file — copy to /etc/fullpcr/fullpcr.env and review
# before enabling the service.
#
# All paths must exist and be readable/writable by the fullpcr user.

# Network bind address.  Keep 127.0.0.1 when fullpcr sits behind a reverse
# proxy (nginx, Caddy).  Only change to 0.0.0.0 on trusted internal networks
# without a reverse proxy — never on a public-facing interface.
FULLPCR_HOST=127.0.0.1

# TCP port (default Streamlit port is 8501).
FULLPCR_PORT=8501

# Persistent data directory for uploaded files and run results.
# Created automatically if missing; must be writable by the fullpcr user.
FULLPCR_DATA_DIR=/srv/fullpcr/data

# PATH must include the directories where obipcr and mfeprimer are installed.
# Adjust the virtualenv path to match your actual install location.
PATH=/opt/fullpcr/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/bin
